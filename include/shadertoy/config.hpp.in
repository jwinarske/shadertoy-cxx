//
// config.hpp — generated build configuration for shadertoy-cxx.
//
// Generated from config.hpp.in by both the CMake and Meson builds.  Consumers
// can test the SHADERTOY_HAVE_* macros to discover which rendering back-ends
// were compiled into the library:
//
//   #include <shadertoy/config.hpp>
//   #if SHADERTOY_HAVE_VULKAN
//   #  include <shadertoy/vk_renderer.hpp>
//   #endif

#pragma once

#define SHADERTOY_VERSION_MAJOR @SHADERTOY_VERSION_MAJOR@
#define SHADERTOY_VERSION_MINOR @SHADERTOY_VERSION_MINOR@
#define SHADERTOY_VERSION_PATCH @SHADERTOY_VERSION_PATCH@
#define SHADERTOY_VERSION_STRING "@SHADERTOY_VERSION_STRING@"

// 1 when the OpenGL ES 3.0 back-end (gl_renderer.hpp) is available, else 0.
#define SHADERTOY_HAVE_GL @SHADERTOY_HAVE_GL@

// 1 when the Vulkan back-end (vk_renderer.hpp) is available, else 0.
#define SHADERTOY_HAVE_VULKAN @SHADERTOY_HAVE_VULKAN@

// 1 when the Shadertoy JSON loader (loader.hpp) is available, else 0.
#define SHADERTOY_HAVE_JSON @SHADERTOY_HAVE_JSON@

// 1 when the PipeWire microphone capture back-end (audio.hpp MakeMicSource) is
// available, else 0.
#define SHADERTOY_HAVE_PIPEWIRE @SHADERTOY_HAVE_PIPEWIRE@

// 1 when the ALSA microphone capture back-end is available, else 0.  When
// neither audio back-end is compiled in, MakeMicSource() returns nullptr and
// kAudio channels render as a silent black texture.  When both are present,
// MakeMicSource() prefers PipeWire unless $SHADERTOY_AUDIO_BACKEND selects one.
#define SHADERTOY_HAVE_ALSA @SHADERTOY_HAVE_ALSA@

// Install location of the bundled shader set (overridable at runtime via the
// SHADERTOY_SHADER_DIR environment variable; see shadertoy::DefaultShaderDir).
#define SHADERTOY_SHADER_DIR "@SHADERTOY_SHADER_DIR@"
